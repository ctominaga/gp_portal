# =====================================================================
# jump-worker — variaveis de ambiente
# Copie para worker/.env e preencha. NUNCA comite o .env real.
# =====================================================================

# --- Fila Redis (origem dos jobs) ---
REDIS_URL=redis://localhost:6379/0

# --- Backend FastAPI (destino dos callbacks HMAC) ---
BACKEND_URL=http://localhost:8000

# --- Autenticacao (precisa bater 1:1 com o .env do backend) ---
# Em dev: usar os mesmos valores do .env da raiz jump-report/.
WORKER_SHARED_SECRET=changeme-min-32-chars
WORKER_HMAC_KEY=changeme-min-32-chars

# --- Identidade desta instancia ---
# Default: hostname da maquina. Util para distinguir multiplos workers.
WORKER_ID=jump-worker-01

# --- Workspace temporario para jobs ---
# Cada job cria WORKSPACE_ROOT/{run_id}/. Removido apos sucesso;
# preservado apos falha para inspecao humana.
WORKSPACE_ROOT=~/.jump-runner/jobs

# --- Heartbeat para /internal/worker-heartbeat ---
HEARTBEAT_S=30

# --- Timeouts de mensageria ---
BRPOP_TIMEOUT_S=30
CALLBACK_TIMEOUT_S=15.0
