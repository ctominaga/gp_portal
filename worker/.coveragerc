# Configuracao de coverage.py para pytest-cov no worker.
#
# Diferenca proposital vs backend/.coveragerc: worker NAO usa greenlet porque
# nao tem ORM async (sqlalchemy[asyncio]/asyncpg/aiosqlite). E pytest-asyncio
# puro com httpx + fakeredis — concurrency=thread basta. Adicionar greenlet
# sem que a lib esteja nas deps quebra com:
#   ConfigError: Couldn't trace with concurrency=greenlet, the module isn't installed.

[run]
concurrency = thread
source = worker
omit =
    */tests/*
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
    \.\.\.
