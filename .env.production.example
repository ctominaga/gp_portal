# =====================================================================
# Jump GP Portal — variáveis de ambiente PRODUÇÃO (Railway).
#
# Este arquivo é APENAS REFERÊNCIA. NÃO copiar para `.env.production`
# e commitar — `.env*` já está no .gitignore (exceção: `.env.example`
# e este `.env.production.example`).
#
# Fluxo recomendado: ler este arquivo, configurar cada variável no
# Railway dashboard (Service → Variables) ou via `railway variables set`
# antes do `railway up`. Vide docs/runbooks/deploy-railway.md.
#
# Geração de secrets seguros (32 bytes random base64):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# =====================================================================

# --- App ---
ENVIRONMENT=prod                                  # prod | beta | staging

# --- Banco e fila ---
# Railway Postgres addon provê DATABASE_URL automaticamente como
# `postgresql://...`. Backend precisa do driver async: prepend
# `+asyncpg`. Em start.sh, fazemos a substituição em runtime se
# detectarmos schema sem driver.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Railway Redis addon — quando flag "TLS" está ativa, REDIS_URL usa
# `rediss://`. Worker local consumirá esta URL via TLS (F5.9b).
REDIS_URL=${{Redis.REDIS_URL}}

# --- JWT (login dos usuários) ---
JWT_SECRET=<GERAR_32_BYTES_RANDOM>                # NUNCA reusar de dev
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=8

# --- Autenticação Worker → Backend (dupla camada) ---
WORKER_SHARED_SECRET=<GERAR_32_BYTES_RANDOM>      # Bearer-like
WORKER_HMAC_KEY=<GERAR_32_BYTES_RANDOM>           # HMAC-SHA256 body

# --- Storage de arquivos ---
# Decisão pendente para o piloto: R2 (configurar abaixo) OU volume
# Railway (apontar STORAGE_BACKEND=local + STORAGE_LOCAL_PATH=/data).
# Vide docs/runbooks/deploy-railway.md §"Storage".
R2_ACCOUNT_ID=<R2_ACCOUNT_ID>
R2_ACCESS_KEY=<R2_ACCESS_KEY>
R2_SECRET_KEY=<R2_SECRET_KEY>
R2_BUCKET=jump-report-proposals
R2_ENDPOINT_URL=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# --- Email transacional (Resend) ---
# Domínio jumplabel.com.br verificado (SPF/DKIM/DMARC).
RESEND_API_KEY=<RESEND_API_KEY>
RESEND_FROM_EMAIL=notificacoes@jumplabel.com.br   # ou outro endereço verificado

# --- Observabilidade ---
SENTRY_DSN=<SENTRY_DSN>                           # opcional, recomendado

# --- CORS ---
# URL EXATA do frontend prod (Railway domain ou custom). Não usar `*`
# em produção — backend rejeita com ValidationError se ENVIRONMENT=prod.
CORS_ORIGINS=https://<frontend-service>.up.railway.app

# =====================================================================
# Frontend (Next.js — lê NEXT_PUBLIC_* em build-time)
# =====================================================================
NEXT_PUBLIC_API_URL=https://<backend-service>.up.railway.app

# =====================================================================
# Seed condicional (Commit 3 F5.9a)
# =====================================================================
# Quando true E ENVIRONMENT em {dev,beta,staging}, start.sh roda
# scripts/seed_pilot.py criando 3 users idempotentes (PMO/GP/CLIENT)
# usando as senhas abaixo. Em ENVIRONMENT=prod, seed é IGNORADO mesmo
# com SEED_ON_STARTUP=true — proteção contra criar contas conhecidas
# em produção real.
SEED_ON_STARTUP=true
SEED_PMO_PASSWORD=<GERAR_RANDOM>
SEED_GP_PASSWORD=<GERAR_RANDOM>
SEED_CLIENT_PASSWORD=<GERAR_RANDOM>
