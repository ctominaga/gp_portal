# =====================================================================
# Jump GP Portal — exemplo de variáveis de ambiente
# Copie para `.env` e preencha. NUNCA comite o `.env` real.
# =====================================================================

# --- App ---
ENVIRONMENT=dev                                   # dev | staging | prod

# --- Banco e fila ---
DATABASE_URL=postgresql+asyncpg://jump:jump@db:5432/jump_report
REDIS_URL=redis://redis:6379/0

# --- JWT (login dos usuários) ---
JWT_SECRET=change-me-in-prod-32-bytes-min
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=8

# --- Autenticação Worker → Backend (dupla camada) ---
WORKER_SHARED_SECRET=change-me-worker-token       # Bearer-like, header X-Worker-Token
WORKER_HMAC_KEY=change-me-worker-hmac-32-bytes    # HMAC-SHA256 do body, header X-Worker-Signature

# --- Storage Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=                                    # console R2 → settings → account ID
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=jump-report-proposals
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# --- Email transacional (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=christopher.tominaga@jumplabel.com.br

# --- Observabilidade ---
SENTRY_DSN=                                       # opcional em dev

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# =====================================================================
# Frontend (lido pelo Next.js)
# =====================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
